{
  "entities": {
    "Program": {
      "title": "Program",
      "description": "Represents a learning program, which can be a course or an event.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the program."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the program."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the program's image, hosted in Firebase Storage."
        },
        "programType": {
          "type": "string",
          "description": "The type of the program.",
          "enum": ["Core", "E-Learning", "Event", "Short"]
        },
        "duration": {
          "type": "string",
          "description": "The duration of the course."
        },
        "level": {
          "type": "string",
          "description": "The difficulty level of the course.",
          "enum": ["Beginner", "Intermediate", "Advanced"]
        },
        "takeaways": {
          "type": "array",
          "description": "A list of key takeaways from the course.",
          "items": {
            "type": "string"
          }
        },
        "price": {
          "type": "string",
          "description": "The price of the program."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the event."
        },
        "time": {
          "type": "string",
          "description": "The time of the event."
        },
        "location": {
          "type": "string",
          "description": "The location of the event."
        },
        "speakers": {
          "type": "array",
          "description": "A list of speakers at the event.",
          "items": {
            "$ref": "#/entities/Speaker"
          }
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        },
        "updatedAt": {
            "type": "string",
            "format": "date-time"
        }
      },
      "required": ["title", "description", "programType"]
    },
    "Speaker": {
      "title": "Speaker",
      "description": "Represents a speaker at an event.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the speaker."
        },
        "title": {
          "type": "string",
          "description": "The title or role of the speaker."
        },
        "avatar": {
          "type": "string",
          "description": "The URL for the speaker's avatar image."
        }
      },
      "required": ["name", "title"]
    },
    "SaleLead": {
      "title": "Sale Lead",
      "description": "Represents a potential customer or lead in the sales pipeline.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "program": { "type": "string" },
        "status": { "type": "string", "enum": ["Prospect", "Lead", "Admitted", "Lost"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "status"]
    },
    "Learner": {
      "title": "Learner",
      "description": "Represents an enrolled student in a program.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "program": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Alumni"] },
        "joinedDate": { "type": "string", "format": "date" }
      },
      "required": ["name", "email", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a financial transaction for a program enrollment.",
      "type": "object",
      "properties": {
        "learnerName": { "type": "string" },
        "program": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Success", "Failed"] },
        "paystackReference": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["learnerName", "program", "amount", "status"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "Represents an image in the gallery.",
      "type": "object",
      "properties": {
        "album": {
          "type": "string",
          "description": "The name of the album the image belongs to."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the image hosted in Firebase Storage."
        },
        "description": {
          "type": "string",
          "description": "A description for the image."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["album", "imageUrl"]
    },
    "User": {
      "title": "User",
      "description": "Represents a user account in the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "avatar": {
          "type": "string",
          "description": "The URL for the user's avatar image."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the system.",
          "enum": ["Learner", "Sales", "Finance", "Business", "Operations", "Admin", "Staff"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user account was created."
        }
      },
      "required": ["name", "email", "role"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/programs/{programId}": {
      "schema": {
        "$ref": "#/entities/Program"
      },
      "description": "Collection of all programs (Core Courses, E-Learning, Events, Short Courses)."
    },
    "/sales/{saleId}": {
      "schema": {
        "$ref": "#/entities/SaleLead"
      },
      "description": "Collection of sales leads."
    },
    "/learners/{learnerId}": {
      "schema": {
        "$ref": "#/entities/Learner"
      },
      "description": "Collection of enrolled learners."
    },
    "/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Collection of financial transactions."
    },
    "/gallery/{imageId}": {
      "schema": {
        "$ref": "#/entities/GalleryImage"
      },
      "description": "Collection of gallery images."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Collection of all users in the system."
    }
  }
}
