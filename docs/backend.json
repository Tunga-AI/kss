{
  "entities": {
    "Cohort": {
      "title": "Cohort",
      "description": "Represents an intake or cohort for a set of programs.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the cohort (e.g., 'Q3 2024 Intake')."
        },
        "status": {
          "type": "string",
          "enum": [
            "Accepting Applications",
            "In Review",
            "Closed"
          ],
          "description": "The current status of the cohort."
        },
        "council": {
          "type": "array",
          "description": "An array of facilitator user IDs who are on the admissions council for this cohort.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "status"
      ]
    },
    "Admission": {
      "title": "Admission",
      "description": "Represents a learner's application and status in the admissions pipeline.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user applying."
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Pending Payment",
            "Pending Test",
            "Pending Review",
            "Admitted",
            "Rejected"
          ]
        },
        "cohortId": {
          "type": "string",
          "description": "The ID of the cohort the learner is applying to."
        },
        "interestedProgramId": {
          "type": "string",
          "description": "The ID of the program the learner initially showed interest in."
        },
        "interestedProgramTitle": {
          "type": "string",
          "description": "The title of the program the learner initially showed interest in."
        },
        "testScore": {
          "type": "number",
          "description": "The score from the sales capability assessment."
        },
        "recommendedProgramId": {
          "type": "string",
          "description": "The ID of the core program recommended by the council."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "name",
        "email",
        "status"
      ]
    },
    "ClassroomSession": {
      "title": "Classroom Session",
      "description": "Represents a live virtual classroom session for a program.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the classroom session."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the session."
        },
        "programId": {
          "type": "string",
          "description": "The ID of the program this session belongs to."
        },
        "facilitatorId": {
          "type": "string",
          "description": "The ID of the facilitator hosting the session."
        },
        "startDateTime": {
          "type": "string",
          "format": "date-time",
          "description": "The start date and time of the session."
        },
        "endDateTime": {
          "type": "string",
          "format": "date-time",
          "description": "The end date and time of the session."
        },
        "status": {
          "type": "string",
          "enum": [
            "Scheduled",
            "In Progress",
            "Completed",
            "Cancelled"
          ],
          "description": "The current status of the session."
        }
      },
      "required": [
        "title",
        "programId",
        "startDateTime",
        "endDateTime",
        "status"
      ]
    },
    "Program": {
      "title": "Program",
      "description": "Represents a learning program, which can be a course or an event.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the program."
        },
        "slug": {
          "type": "string",
          "description": "The unique, URL-friendly identifier for the program."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the program."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the program's image, hosted in Firebase Storage."
        },
        "programType": {
          "type": "string",
          "description": "The type of the program.",
          "enum": [
            "Core",
            "E-Learning",
            "Event",
            "Short"
          ]
        },
        "duration": {
          "type": "string",
          "description": "The duration of the course."
        },
        "level": {
          "type": "string",
          "description": "The difficulty level of the course.",
          "enum": [
            "Beginner",
            "Intermediate",
            "Advanced"
          ]
        },
        "takeaways": {
          "type": "array",
          "description": "A list of key takeaways from the course.",
          "items": {
            "type": "string"
          }
        },
        "price": {
          "type": "string",
          "description": "The price of the program."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the event."
        },
        "time": {
          "type": "string",
          "description": "The time of the event."
        },
        "location": {
          "type": "string",
          "description": "The location of the event."
        },
        "speakers": {
          "type": "array",
          "description": "A list of speakers at the event.",
          "items": {
            "$ref": "#/entities/Speaker"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "title",
        "slug",
        "description",
        "programType"
      ]
    },
    "Speaker": {
      "title": "Speaker",
      "description": "Represents a speaker at an event.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the speaker."
        },
        "title": {
          "type": "string",
          "description": "The title or role of the speaker."
        },
        "avatar": {
          "type": "string",
          "description": "The URL for the speaker's avatar image."
        }
      },
      "required": [
        "name",
        "title"
      ]
    },
    "SaleLead": {
      "title": "Sale Lead",
      "description": "Represents a potential customer or lead in the sales pipeline.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "program": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Prospect",
            "Lead",
            "Admitted",
            "Lost"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "email",
        "status"
      ]
    },
    "Learner": {
      "title": "Learner",
      "description": "Represents an enrolled student in a program.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "program": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "Inactive",
            "Alumni"
          ]
        },
        "joinedDate": {
          "type": "string",
          "format": "date"
        }
      },
      "required": [
        "name",
        "email",
        "status"
      ]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a financial transaction for a program enrollment.",
      "type": "object",
      "properties": {
        "learnerName": {
          "type": "string"
        },
        "learnerEmail": {
          "type": "string"
        },
        "program": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "Pending",
            "Success",
            "Failed"
          ]
        },
        "paystackReference": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "learnerName",
        "learnerEmail",
        "program",
        "amount",
        "status"
      ]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "Represents an image in the gallery.",
      "type": "object",
      "properties": {
        "album": {
          "type": "string",
          "description": "The name of the album the image belongs to."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the image hosted in Firebase Storage."
        },
        "description": {
          "type": "string",
          "description": "A description for the image."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "album",
        "imageUrl"
      ]
    },
    "User": {
      "title": "User",
      "description": "Represents a user account in the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "avatar": {
          "type": "string",
          "description": "The URL for the user's avatar image."
        },
        "organizationId": {
          "type": "string",
          "description": "The ID of the organization this user belongs to, if any."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the system.",
          "enum": [
            "Learner",
            "Sales",
            "Finance",
            "Business",
            "Operations",
            "Admin",
            "Facilitator",
            "BusinessAdmin",
            "BusinessLearner"
          ]
        },
        "status": {
          "type": "string",
          "description": "The status of the user account.",
          "enum": [
            "Active",
            "Inactive"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user account was created."
        }
      },
      "required": [
        "name",
        "email",
        "role",
        "status"
      ]
    },
    "Organization": {
      "title": "Organization",
      "description": "Represents a business or company with a B2B subscription.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the organization."
        },
        "adminId": {
          "type": "string",
          "description": "The user ID of the business admin for this organization."
        },
        "tier": {
          "type": "string",
          "enum": [
            "Startup",
            "Growth",
            "Enterprise",
            "Custom"
          ],
          "description": "The subscription tier."
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "Trial",
            "Expired",
            "Cancelled"
          ],
          "description": "The status of the subscription."
        },
        "subscriptionEndDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date when the current subscription expires."
        },
        "maxLearners": {
          "type": "number",
          "description": "The maximum number of learners allowed under the current plan."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "adminId",
        "tier",
        "status"
      ]
    },
    "Branding": {
      "title": "Branding",
      "description": "Stores branding assets like logo URL.",
      "type": "object",
      "properties": {
        "logoUrl": {
          "type": "string",
          "description": "The URL of the company logo."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Represents a certificate issued to a learner for completing a program.",
      "type": "object",
      "properties": {
        "learnerName": {
          "type": "string",
          "description": "The name of the learner who received the certificate."
        },
        "learnerEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the learner."
        },
        "programTitle": {
          "type": "string",
          "description": "The title of the program for which the certificate was issued."
        },
        "issuedDate": {
          "type": "string",
          "format": "date-time",
          "description": "The date the certificate was issued."
        },
        "certificateUrl": {
          "type": "string",
          "description": "A URL to the generated certificate file (e.g., PDF)."
        }
      },
      "required": [
        "learnerName",
        "learnerEmail",
        "programTitle",
        "issuedDate"
      ]
    }
  },
  "auth": {
    "providers": [
      "Email"
    ]
  },
  "firestore": {
    "/programs/{programId}": {
      "schema": {
        "$ref": "#/entities/Program"
      },
      "description": "Collection of all programs (Core Courses, E-Learning, Events, Short Courses)."
    },
    "/sales/{saleId}": {
      "schema": {
        "$ref": "#/entities/SaleLead"
      },
      "description": "Collection of sales leads."
    },
    "/learners/{learnerId}": {
      "schema": {
        "$ref": "#/entities/Learner"
      },
      "description": "Collection of enrolled learners."
    },
    "/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Collection of financial transactions."
    },
    "/gallery/{imageId}": {
      "schema": {
        "$ref": "#/entities/GalleryImage"
      },
      "description": "Collection of gallery images."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Collection of all users in the system."
    },
    "/organizations/{organizationId}": {
      "schema": {
        "$ref": "#/entities/Organization"
      },
      "description": "Collection of B2B client organizations."
    },
    "/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Branding"
      },
      "description": "General application settings. Expects a single document with ID 'branding'."
    },
    "/classroom/{classroomId}": {
      "schema": {
        "$ref": "#/entities/ClassroomSession"
      },
      "description": "Collection of live classroom sessions."
    },
    "/certificates/{certificateId}": {
      "schema": {
        "$ref": "#/entities/Certificate"
      },
      "description": "Collection of all issued certificates."
    },
    "/cohorts/{cohortId}": {
      "schema": {
        "$ref": "#/entities/Cohort"
      },
      "description": "Collection of all program cohorts/intakes."
    },
    "/admissions/{admissionId}": {
      "schema": {
        "$ref": "#/entities/Admission"
      },
      "description": "Collection of all learner admission applications."
    }
  }
}
