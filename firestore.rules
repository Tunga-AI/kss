rules_version = '2';

service cloud.firestore {
  match /databases/kenyasales/documents {
    match /programs/{programId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }

    match /learners/{learnerId} {
      allow read, write: if request.auth != null;
    }

    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /organizations/{orgId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
    
    match /cohorts/{cohortId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    match /admissions/{admissionId} {
      function isOwner() {
        return request.auth.uid == resource.data.userId;
      }
      function isCouncilMember() {
        let cohortId = resource.data.cohortId;
        return request.auth.uid in get(/databases/$(database)/documents/cohorts/$(cohortId)).data.council;
      }
      function isAdmin() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
      }

      allow read: if isAdmin() || isOwner() || isCouncilMember();
      allow create: if request.auth.uid != null;
      allow update: if isAdmin() || isCouncilMember();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    match /classroom/{classroomId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Facilitator');
    }

    match /certificates/{certificateId} {
      allow read: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' || resource.data.learnerEmail == request.auth.email);
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }
  }
}
