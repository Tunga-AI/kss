rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to courses, events, and elearning
    match /courses/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /elearning/{courseId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
